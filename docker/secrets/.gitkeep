# docker/secrets/.gitkeep
# Este directorio contiene los secretos de Docker.
# Los archivos .txt con contraseñas están excluidos del repositorio en .gitignore.
#
# Comandos para crear los secretos localmente, se ejecutan en PowerShell:
#
#   "tu_password_segura" | Out-File -Encoding ASCII -NoNewline db_password.txt
#   "ClaveJWTMinimo32Caracteres2026!" | Out-File -Encoding ASCII -NoNewline jwt_secret.txt
#   "xkeysib-tu-api-key-brevo" | Out-File -Encoding ASCII -NoNewline brevo_api_key.txt
